{
  "name": "forza-color-picker",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "generate-colors": "node scripts/generate-colors.mjs",
    "build": "npm run generate-colors && remix vite:build && node scripts/post-build.mjs",
    "dev": "npm run generate-colors && vite dev",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "typecheck": "tsc",
    "build-csv": "python ./util/scripts/forza-color-parser.py",
    "deploy": "npm run build && gh-pages -d build/client"
  },
  "dependencies": {
    "@remix-run/node": "^2.15.0",
    "@remix-run/react": "^2.15.0",
    "isbot": "^4.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.15.0",
    "@types/react": "^18.2.20",
    "@types/react-dom": "^18.2.7",
    "autoprefixer": "^10.4.19",
    "gh-pages": "^6.1.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.1.6",
    "vite": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
